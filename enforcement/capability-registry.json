  "aliases": {
    "arc42": "arc42-documentation",
    "c4-architecture": "c4-architecture-diagrams",
    "web-scaffolding": "frontend-scaffolding",
    "tauri-web-scaffolding": "frontend-scaffolding",
    "web-core-code-generation": "frontend-core-code-generation",
    "web-core": "frontend-core-code-generation",
    "contracts-generation": "frontend-contracts-generation",
    "view-model-generation": "frontend-view-model-generation",
