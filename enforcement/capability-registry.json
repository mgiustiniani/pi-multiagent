  "fileRules": [
    {
      "pattern": "README.md",
      "capability": "readme-management",
      "owner": "documenter"
    },
    {
      "pattern": "PLAN.md",
      "capability": "plan-management",
      "owner": "documenter"
    },
    {
      "pattern": "docs/arc42/**",
      "capability": "arc42-documentation",
      "owner": "documenter"
    },
    {
      "pattern": "docs/adr/**",
      "capability": "adr-management",
      "owner": "documenter"
    },
    {
      "pattern": "docs/test-report.md",
      "capability": "test-report-documentation",
      "owner": "documenter"
    },
    {
      "pattern": "docs/quality-report.md",
      "capability": "quality-report-documentation",
      "owner": "documenter"
    },
    {
      "pattern": "docs/c4/**",
      "capability": "structurizr-dsl",
      "owner": "c4model"
    },
    {
      "pattern": "pnpm-workspace.yaml",
      "capability": "frontend-workspace-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "package.json",
      "capability": "package-manager-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "apps/web/package.json",
      "capability": "package-manager-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "packages/*/package.json",
      "capability": "package-manager-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "tsconfig*.json",
      "capability": "typescript-config-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "apps/web/tsconfig*.json",
      "capability": "typescript-config-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "packages/*/tsconfig*.json",
      "capability": "typescript-config-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "apps/web/vite.config.*",
      "capability": "vite-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "packages/*/vite.config.*",
      "capability": "vite-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "apps/web/eslint.config.*",
      "capability": "eslint-prettier-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "packages/*/eslint.config.*",
      "capability": "eslint-prettier-setup",
      "owner": "frontend-scaffolder"
    },
    {
      "pattern": "packages/web-core/**",
      "capability": "frontend-core-code-generation",
      "owner": "frontend-core-coder"
    },
    {
      "pattern": "packages/contracts/**",
      "capability": "frontend-contracts-generation",
      "owner": "frontend-core-coder"
    },
    {
      "pattern": "packages/ui/**",
      "capability": "frontend-ui-generation",
      "owner": "frontend-ui-coder"
    },
    {
      "pattern": "packages/browser-adapters/**",
      "capability": "browser-adapter-generation",
      "owner": "browser-adapter-coder"
    },
    {
      "pattern": "apps/web/src/adapters/**",
      "capability": "browser-adapter-generation",
      "owner": "browser-adapter-coder"
    },
    {
      "pattern": "apps/web/src/bootstrap/**",
      "capability": "browser-bootstrap-wiring",
      "owner": "browser-adapter-coder"
    },
    {
      "pattern": "apps/web/src/main.*",
      "capability": "browser-bootstrap-wiring",
      "owner": "browser-adapter-coder"
    },
    {
      "pattern": "apps/web/src/**/*.test.ts",
      "capability": "frontend-web-testing",
      "owner": "frontend-tester"
    },
    {
      "pattern": "apps/web/src/**/*.spec.ts",
      "capability": "frontend-web-testing",
      "owner": "frontend-tester"
    },
    {
      "pattern": "apps/web/src/**/*.test.tsx",
      "capability": "frontend-web-testing",
      "owner": "frontend-tester"
    },
    {
      "pattern": "apps/web/src/**/*.spec.tsx",
      "capability": "frontend-web-testing",
      "owner": "frontend-tester"
    },
    {
      "pattern": "apps/web/src/**",
      "capability": "frontend-app-code-generation",
      "owner": "frontend-app-coder"
    },
    {
      "pattern": "apps/web/tests/**",
      "capability": "frontend-web-testing",
      "owner": "frontend-tester"
    },
    {
      "pattern": "packages/ui/**/*.test.ts",
      "capability": "component-test-generation",
      "owner": "frontend-tester"
    },
    {
      "pattern": "packages/ui/**/*.spec.ts",
      "capability": "component-test-generation",
      "owner": "frontend-tester"
    },
    {
      "pattern": "packages/web-core/**/*.test.ts",
      "capability": "unit-test-generation",
      "owner": "frontend-tester"
    },
    {
      "pattern": "packages/web-core/**/*.spec.ts",
      "capability": "unit-test-generation",
      "owner": "frontend-tester"
    },
    {
      "pattern": "packages/browser-adapters/**/*.test.ts",
      "capability": "unit-test-generation",
      "owner": "frontend-tester"
    },
    {
      "pattern": "packages/browser-adapters/**/*.spec.ts",
      "capability": "unit-test-generation",
      "owner": "frontend-tester"
    },
    {
      "pattern": ".llm-wiki/**",
      "capability": "wiki-maintenance",
      "owner": "domain-expert"
    },
    {
      "pattern": ".wiki/**",
      "capability": "wiki-maintenance",
      "owner": "domain-expert"
    },
    {
      "pattern": "raw/**",
      "capability": "domain-source-ingestion",
      "owner": "domain-expert"
    },
    {
      "pattern": "wiki/**",
      "capability": "domain-knowledge-query",
      "owner": "domain-expert"
    }
  ],
  "sharedOwnership": {
    "PLAN.md": {
      "contentSource": "workflow-planner",
      "fileWriter": "documenter"
    },
    "docs/test-report.md": {
      "contentSource": "workflow-tester",
      "fileWriter": "documenter"
    }
  }
}
